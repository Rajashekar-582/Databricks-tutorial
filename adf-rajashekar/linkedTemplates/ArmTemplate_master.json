{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-rajashekar"
		},
		"blob2adf_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'blob2adf'"
		},
		"sql2adf_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserverd004.database.windows.net"
		},
		"sql2adf_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().data base}"
		},
		"sql2adf_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "admin123"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-rajashekar_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"blob2adf_connectionString": {
						"value": "[parameters('blob2adf_connectionString')]"
					},
					"sql2adf_properties_typeProperties_server": {
						"value": "[parameters('sql2adf_properties_typeProperties_server')]"
					},
					"sql2adf_properties_typeProperties_database": {
						"value": "[parameters('sql2adf_properties_typeProperties_database')]"
					},
					"sql2adf_properties_typeProperties_userName": {
						"value": "[parameters('sql2adf_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}